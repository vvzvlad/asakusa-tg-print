# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
# TELEGRAM_API_SERVER=http://localhost:8081
# Comma-separated Telegram user IDs allowed to print (empty = nobody)
ALLOWED_USER_IDS=

# Label Maker service (POST /api/generate-pdf)
LABEL_MAKER_URL=http://localhost:8000
LABEL_MAKER_TIMEOUT=60
TEMPLATE_PATH=data/label_template.json
# Rotate PDF 90°. false = landscape 58x40mm (direct PDF print to CUPS)
LABEL_ROTATE=false

# CUPS / printer (printed via `lp` over IPP)
CUPS_HOST=10.31.50.63
PRINTER_NAME=XP-365B
PRINTER_MEDIA=Custom.165x114pt
PRINTER_FIT_TO_PAGE=true

LOG_LEVEL=INFO
